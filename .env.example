# ─────────────────────────────────────────────
# Wollnut Labs — Environment Variables
# Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────

# ── APP ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Wollnut Labs

# ── DATABASE ───────────────────────────────
DATABASE_URL=postgresql://wollnut:wollnut@localhost:5432/wollnut_dev

# ── AUTH (NextAuth.js) ─────────────────────
NEXTAUTH_SECRET=                    # Generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── E2E NETWORKS (CRITICAL) ───────────────
# Get these from your E2E Networks dashboard:
# https://myaccount.e2enetworks.com → API Tokens
E2E_API_TOKEN=                      # ← YOUR E2E PERSONAL ACCESS TOKEN
E2E_PROJECT_ID=                     # ← YOUR E2E PROJECT ID
E2E_CONTACT_PERSON_ID=              # ← YOUR E2E CONTACT PERSON ID
E2E_API_BASE_URL=https://api.e2enetworks.com/myaccount/api/v1

# ── RAZORPAY ───────────────────────────────
RAZORPAY_KEY_ID=                    # rzp_test_...
RAZORPAY_KEY_SECRET=                # your_key_secret
RAZORPAY_WEBHOOK_SECRET=            # your_webhook_secret

# ── REDIS (Job Queues) ────────────────────
REDIS_URL=redis://localhost:6379

# ── EMAIL (Transactional) ────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@wollnutlabs.com

# ── CREDITS CONFIG ────────────────────────
# New user signup bonus (in USD)
NEW_USER_CREDITS=5.00
# Low-credits alert threshold (in USD)
LOW_CREDITS_THRESHOLD=2.00
# Minimum credits to launch an instance (in hours of cheapest GPU)
MIN_CREDITS_HOURS=1
